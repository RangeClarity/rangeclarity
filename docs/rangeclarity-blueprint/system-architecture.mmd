%% RangeClarity — system architecture (5 layers).
%% Arrow legend: ==> solid = runtime market data | -.-> dotted = spec/parity/future
%% | "outbound webhook" = Pine alert out | "BLOCKED" link = unsupported backend->Pine API.
flowchart TB
  subgraph L1["Layer 1 · TradingView Data Plane"]
    OHLCV["Chart OHLCV + volume (direct)"]
    HTF["Weekly confirm (request.security, lookahead_off)"]
    BENCH["SPY / QQQ / sector ETF (request.security)"]
    FIN["TV financials / economic (coverage varies)"]
    INP["User inputs"]
  end
  subgraph L2["Layer 2 · Pine Runtime Engine (confirmed-bar)"]
    GATE["1 Data Quality Gate"] --> MAS["2 MA Structure"] --> TREND["3 Trend"] --> ZONES["4 S/R Zone Engine"] --> LOC["5 Price Location"] --> EXT["6 Extension"] --> RS["7 Rel Strength"] --> NOEDGE["8 No-Edge Filter"] --> SQ["9 Structure Score"] --> EQ["10 Entry Score"] --> SM["11 State Machine"] --> RCODE["12 Reason Codes"]
    RCODE --> VIZ["13 Viz Adapter"]
    RCODE --> ALERT["14 Alert Adapter"]
  end
  subgraph L3["Layer 3 · TradingView Product Surface"]
    CHART["Candles + volume + MA50/100/200 + <=4 zones + price marker"]
    DASH["Dashboard: State / Entry / Structure / Location / Risk / Why"]
    PLOTS["Numeric plots 0-9 (screener-ready, hideable)"]
  end
  subgraph L4["Layer 4 · Private Canonical TS Core (spec + tests)"]
    SPEC["Typed contracts + formulas + thresholds + weights + engine version"]
    FIX["Golden fixtures + expected outputs"]
    TESTS["Unit + edge-case tests + parity check"]
  end
  subgraph L5["Layer 5 · Backend + Future SaaS"]
    BE["Optional backend: webhook ingest, alert history, journal, analytics"]
    SAAS["Future SaaS: licensed data + canonical engine + Radar + daily brief + mobile"]
  end

  L1 ==> L2
  VIZ ==> CHART
  VIZ ==> DASH
  SM ==> PLOTS
  SPEC -. "specification" .-> L2
  L2 -. "debug / CSV export" .-> TESTS
  FIX -. "expected outputs" .-> TESTS
  ALERT == "outbound webhook (paid plan)" ==> BE
  BE -. "future" .-> SAAS
  SPEC -. "same core later" .-> SAAS
  BE -. "BLOCKED: Pine cannot call our API" .-> L2

  MOAT["MOAT — calibrated zone ranking · separate Structure/Entry · first-class No-Edge · golden fixtures across regimes · parity tests · versioned contract · RangeClarity visual language"]
  L4 -. "defensibility" .-> MOAT
