%% RangeClarity — runtime data flow (Pine) + outbound webhook.
flowchart LR
  CHART["Chart OHLCV + volume"] ==> GATE["Data Quality Gate"]
  WK["Weekly (request.security [1] closed)"] ==> GATE
  SPY["SPY / sector (request.security)"] ==> RS["Rel Strength"]
  GATE ==> FEAT["Features: MA50/100/200, pivots, ATR, RVOL"]
  FEAT ==> ZONES["S/R zones (ATR-clustered, confirmed pivots)"]
  FEAT ==> SCORES["Structure score + Entry score"]
  RS ==> SCORES
  ZONES ==> STATE["State machine -> 5 states + reasons"]
  SCORES ==> STATE
  STATE ==> UI["Dashboard + chart zones + plots 0-9"]
  STATE == "confirmed bar" ==> ALERT["alert() event"]
  ALERT == "outbound webhook" ==> BE["RangeClarity backend (optional)"]
  BE -. "BLOCKED back to Pine" .-> CHART
