# --- Providers (each provider reads only the keys it needs) ---
ANTHROPIC_API_KEY=            # Claude Code provider
OPENAI_API_KEY=               # OpenAI Codex provider
ANTIGRAVITY_API_KEY=          # AntiGravity provider
ANTIGRAVITY_BASE_URL=

# --- Linear (writes are ALWAYS gated behind explicit user approval) ---
LINEAR_API_KEY=
LINEAR_TEAM_ID=               # e.g. DEA
LINEAR_DEFAULT_PROJECT_ID=

# --- Storage ---
DATABASE_URL="file:./council.db"   # SQLite for MVP; swap to Postgres later

# --- Safety ---
COUNCIL_ALLOW_LINEAR_WRITES=false  # hard gate; UI approval still required on top of this
