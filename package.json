{
  "name": "rangeclarity",
  "version": "0.1.0",
  "private": true,
  "description": "RangeClarity — MVP foundation (full-stack Next.js + TypeScript).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/test/run-tests.mjs",
    "test:unit": "vitest run",
    "test:e2e": "playwright test -c tests/playwright.config.ts",
    "verify": "npm run health && npm run build",
    "health": "npm run typecheck && npm run lint && npm run test",
    "ops:status": "node scripts/ops-status.mjs"
  },
  "dependencies": {
    "next": "^15.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@types/node": "^20.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
