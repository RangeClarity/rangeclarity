# RangeClarity environment variables
# Copy this file to `.env.local` for local dev, or set these in your host's
# dashboard (e.g. Vercel → Project → Settings → Environment Variables).
# This file contains PLACEHOLDERS ONLY — never commit real secrets.
# `.env` and `.env*.local` are gitignored.

# ---------------------------------------------------------------------------
# Required for production: NONE.
# The site builds and runs with no environment variables set.
# ---------------------------------------------------------------------------

# Optional public app name (safe to expose; NEXT_PUBLIC_* is sent to the browser).
# NEXT_PUBLIC_APP_NAME=RangeClarity

# ---------------------------------------------------------------------------
# Waitlist persistence (optional)
# ---------------------------------------------------------------------------
# The waitlist form (/api/waitlist) writes signups to a local newline-delimited
# JSON file by default (.data/waitlist.jsonl).
#
# IMPORTANT: serverless hosts (Vercel, Netlify functions) have an ephemeral,
# read-only filesystem at runtime, so file-based persistence will NOT retain
# signups in production. The endpoint fails gracefully if it cannot write.
#
# To capture signups in production you have two clean options:
#   1) Point WAITLIST_FILE at a writable volume (only on a VPS / persistent host).
#   2) Replace `addEntry` in lib/waitlist.ts with a hosted store/ESP
#      (e.g. Vercel KV/Postgres, Supabase, Airtable, ConvertKit, Mailchimp).
# WAITLIST_FILE=.data/waitlist.jsonl

# If/when you wire a hosted store or ESP, document its keys here as placeholders, e.g.:
# WAITLIST_PROVIDER_API_KEY=
# WAITLIST_PROVIDER_LIST_ID=

# ---------------------------------------------------------------------------
# Hermes → Linear integration (optional; safe by default)
# ---------------------------------------------------------------------------
# Easiest setup:  bash scripts/setup-linear.sh   (stores the key locally, hidden)
# Commands:       npm run linear:health | linear:teams | linear:test-issue
#                 npm run hermes:linear:validate | :dry-run | :sync
#
# PLACEHOLDERS ONLY. Put the real LINEAR_API_KEY in .env / .env.local (gitignored)
# or the Hermes task's own environment — NEVER commit a real token.
#
# Linear personal API key. Auth header is `Authorization: <key>` (no "Bearer").
# Linear → Settings → Security & access → API → Personal API keys.
LINEAR_API_KEY=
# Target team — set EITHER the key (e.g. DEA) or the UUID. Key is easiest.
LINEAR_TEAM_KEY=
LINEAR_TEAM_ID=
# Optional: target project id. If unset, issues land in the team backlog.
LINEAR_PROJECT_ID=
#
# WRITE SWITCH — the one control that matters. Default false = DRY-RUN (no writes).
# Set to true ONLY after reviewing a dry-run. Then `sync` / `test-issue` will write.
LINEAR_WRITE_ENABLED=false
#
# Optional extra brake: if set to true, forces dry-run even when writes are enabled.
# (Legacy alias HERMES_ALLOW_LINEAR_WRITE=true is also still honored.)
# LINEAR_DRY_RUN=true
#
# Where Hermes reads tasks from. "docs" = docs/kanban.md is the source of truth.
HERMES_SOURCE_OF_TRUTH=docs

# --- RangeClarity paid beta (manual fulfilment; no live payments) ---
# Active payment provider: manual (default) | lemonsqueezy | paddle | whop | stripe
PAYMENT_PROVIDER=manual
# Manual payment-link placeholders for paid plans (replace with real links).
MANUAL_PAYMENT_LINK_29=
MANUAL_PAYMENT_LINK_49=
# Gate for /beta/admin manual-fulfilment console. Set a strong value before sharing.
ADMIN_TOKEN=
# TradingView resource/referral link shown on /beta.
NEXT_PUBLIC_TRADINGVIEW_URL=https://www.tradingview.com/
# Optional: writable storage paths (default .data/* is ephemeral on serverless).
# BETA_SIGNUPS_FILE=
# BETA_FEEDBACK_FILE=
# Provider integration slots (set when wiring a real provider; none are live):
# LEMONSQUEEZY_API_KEY=   LEMONSQUEEZY_STORE_ID=   LEMONSQUEEZY_VARIANT_ID=
# PADDLE_API_KEY=         PADDLE_PRICE_ID=
# WHOP_API_KEY=           WHOP_PLAN_ID=
# STRIPE_SECRET_KEY=      STRIPE_PRICE_ID=
